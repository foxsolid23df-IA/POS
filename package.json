{
  "name": "nexum-pos",
  "version": "1.1.2",
  "engines": {
    "node": ">=20"
  },
  "description": "NEXUM POS - Sistema profesional de punto de venta",
  "main": "electron-main.js",
  "scripts": {
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build:all && electron-builder",
    "build:all": "npm run build:frontend && npm run prepare:backend",
    "build:frontend": "cd frontend && npm run build && cd ..",
    "prepare:backend": "node scripts/prepare-backend.js",
    "dist": "npm run build:all && electron-builder --win --x64",
    "build": "npm run build:frontend"
  },
  "keywords": [
    "pos",
    "punto-de-venta",
    "inventario",
    "ventas"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.nexumpos.app",
    "productName": "NEXUM POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "icon.ico",
      "icon.png",
      "frontend/dist/**/*",
      "!backend/**",
      "!node_modules",
      "!scripts",
      "!*.md",
      "!*.sql",
      "!*.bat"
    ],
    "extraResources": [
      {
        "from": "bin/node.exe",
        "to": "bin/node.exe"
      },
      {
        "from": "backend",
        "to": "app/backend",
        "filter": [
          "**/*",
          "!node_modules/**"
        ]
      },
      {
        "from": "backend/node_modules",
        "to": "app/backend/node_modules"
      },
      {
        "from": "backend/.env",
        "to": "app/backend/.env"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NEXUM POS"
    }
  },
  "dependencies": {
    "node-machine-id": "^1.1.12"
  }
}
