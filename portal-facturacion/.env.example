# ══════════════════════════════════════════════════
# Portal de Auto-Facturación — Variables de Entorno
# ══════════════════════════════════════════════════
# Este archivo documenta TODAS las variables que soporta el portal.
# Cada despliegue en Vercel debe configurar sus propias variables
# apuntando a su proyecto de Supabase y branding de negocio.

# ─── Supabase (OBLIGATORIAS) ───
# Estas variables cambian POR NEGOCIO. Cada Vercel apunta a su propio Supabase.
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Branding (OPCIONALES) ───
# Nombre del negocio que se muestra bajo el título "Auto-Facturación"
VITE_APP_NAME=Mi Negocio

# Título de la pestaña del navegador
VITE_APP_TITLE=Auto-Facturación | Mi Negocio

# Color de acento (valor HSL Hue 0-360):
#   220 = Azul (POS default)
#   160 = Teal/Verde-Azulado (ideal para Lavandería)
#   270 = Púrpura
#   30  = Naranja
#   0   = Rojo
VITE_ACCENT_HUE=220
